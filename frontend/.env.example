# Fire Crow Frontend Environment Configuration
# Copy this file to .env.local and adjust for your deployment.

# ==============================================================================
# 1. API CONNECTIVITY
# ==============================================================================
# The base URL of the Fire Crow Backend API.
# Local development default: http://localhost:8000/api/v1
# Production example: https://fire-crow-backend.onrender.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Enable debugging or specific logging features in the frontend
# NEXT_PUBLIC_DEBUG=true
