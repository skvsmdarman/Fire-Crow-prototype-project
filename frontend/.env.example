# Fire Crow Frontend Environment
# Copy to frontend/.env.local for local development.
#
# The dev launcher injects this value automatically when it starts the frontend.
# Set it manually when running `npm run dev` directly inside frontend/.

# Local backend API:
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# If the backend launcher falls forward to another port, update accordingly:
# NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1

# Production/staging example:
# NEXT_PUBLIC_API_URL=https://api.your-firecrow-domain.com/api/v1
