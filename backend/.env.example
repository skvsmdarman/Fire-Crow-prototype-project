# Fire Crow backend environment template.
# For local development you can usually leave DEBUG=true and SQLite enabled.
# For production use the root `.env.example` template instead and provide real secrets.

# Core runtime
DEBUG=true
PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Security
SECRET_KEY=
ENCRYPTION_KEY=
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
CSRF_ENABLED=true

# Database and queue
DATABASE_URL=sqlite:///./firecrow.db
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Sandbox / scanners
FIRE_CROW_MOCK_SANDBOX=true
FIRE_CROW_SCANNER_IMAGE=ghcr.io/johan-droid/firecrow-scanner:2026-06-06
REPORT_LOCAL_FALLBACK=true

# Optional OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
LLM_CHAT_ASSISTANT=false
LLM_DASHBOARD_INSIGHT=false
LLM_ATTACK_CHAIN_NAMING=false
LLM_PR_DESCRIPTION=false

# Optional email delivery
RESEND_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=reports@firecrow.dev

# Optional object storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=firecrow-reports

# Legal / policy versions
PRIVACY_POLICY_VERSION=2026-06-06
TERMS_VERSION=2026-06-06
