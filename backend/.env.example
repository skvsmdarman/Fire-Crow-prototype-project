# Fire Crow Backend Environment
# Copy to backend/.env.local for local development, or set these variables in
# your deployment platform for staging/production.
#
# Load order used by backend.app.config:
# 1. .env
# 2. backend/.env
# 3. .env.local
# 4. backend/.env.local

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8000
HOST=0.0.0.0
DEBUG=true

# Render/staging deployment default for the hosted Fire Crow service.
# For local development, override this in backend/.env.local with:
# FRONTEND_URL=http://localhost:3000
# OAuth callbacks and post-login redirects are derived from this value.
FRONTEND_URL=https://fire-crow.onrender.com

# Optional comma-separated list of browser origins allowed by CORS.
# In production, include the same origin used by FRONTEND_URL.
CORS_ORIGINS=https://fire-crow.onrender.com

# Use a long random value in every real environment.
# Example generator: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace_with_a_long_random_secret_at_least_32_bytes
ENCRYPTION_KEY=replace_with_a_long_random_encryption_key_at_least_32_bytes

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local lightweight mode:
DATABASE_URL=sqlite:///./firecrow.db

# Shared/staging/production mode:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/firecrow

# ---------------------------------------------------------------------------
# Redis and Celery
# ---------------------------------------------------------------------------
# Redis is used by the Celery worker. The API can fall back to local background
# execution when Redis is unavailable during development.
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Sandbox Runtime
# ---------------------------------------------------------------------------
# true  = local/CI simulation mode, no Docker/Kali required.
# false = real Docker sandbox mode using Kali-backed runtime resources.
FIRE_CROW_MOCK_SANDBOX=false

# Do not build user-provided Dockerfiles in SaaS production unless this is
# explicitly reviewed and enabled for a controlled environment.
FIRE_CROW_ALLOW_UNTRUSTED_DOCKERFILE_BUILD=false

# Scanner runtime image used for controlled sandbox validation. Production must
# use a pinned tag; :latest is rejected when DEBUG=false.
FIRE_CROW_SCANNER_IMAGE=ghcr.io/johan-droid/firecrow-scanner:2026-06-06

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------
# OAuth is optional. Leave these blank for the local workspace login flow.
# In production, configure the GitHub OAuth app callback using FRONTEND_URL's
# matching deployed domain and the backend callback route used by routes_auth.py.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Accepts either JSON or a comma-separated string.
# Example: repo,workflow,read:org,user:email
GITHUB_OAUTH_SCOPES=repo,workflow,read:org,user:email

# Optional token used by the GitHub agent for issue/PR write operations.
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
# Optional. Leave blank unless enabling Google sign-in.
# In production, Google OAuth authorized origins/callbacks must use the deployed
# frontend/backend URLs, not localhost.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
# Resend is optional and used for report delivery when configured.
RESEND_API_KEY=
BREVO_API_KEY=
SENDER_EMAIL=reports@firecrow.dev

# SMTP/Gmail is optional and is attempted before Resend for some alerts.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Report Storage
# ---------------------------------------------------------------------------
# Optional Cloudflare R2 / S3-compatible storage for PDF reports.
# Leave blank to keep reports on the local filesystem.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=firecrow-reports

# ---------------------------------------------------------------------------
# AI Providers
# ---------------------------------------------------------------------------
# Optional keys for enhanced analysis and scoring. The local smoke path does
# not require these values.
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_FALLBACK_MODEL=
GEMINI_ENABLE_FALLBACK_MODEL=true
GEMINI_TIMEOUT_SECONDS=30
LLM_CHAT_ASSISTANT=false
LLM_DASHBOARD_INSIGHT=false
LLM_ATTACK_CHAIN_NAMING=false
LLM_PR_DESCRIPTION=false
OPENAI_API_KEY=

# OAuth Provider Console Redirect URI Notes:
# GitHub callback: <backend-origin>/api/v1/auth/github/callback
# Google callback: <backend-origin>/api/v1/auth/google/callback
