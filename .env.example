# Fire Crow production-oriented environment template.
# Copy to `.env` for local production-like testing or load equivalent values from a secrets manager.

# Core runtime
DEBUG=false
SECRET_KEY=
ENCRYPTION_KEY=
DATABASE_URL=postgresql://firecrow:change_me@localhost:5432/firecrow
REDIS_URL=redis://:change_me@localhost:6379/0
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Scanner/runtime behavior
FIRE_CROW_MOCK_SANDBOX=false
FIRE_CROW_SCANNER_IMAGE=ghcr.io/johan-droid/firecrow-scanner:2026-06-06
REPORT_LOCAL_FALLBACK=true

# Enterprise controls
MFA_ENFORCE_FOR_ADMINS=true
SSO_ALLOW_AUTO_PROVISION=false
PAM_MAX_DURATION_MINUTES=480
IAM_DORMANT_DAYS_THRESHOLD=90

# LLM features default off
LLM_CHAT_ASSISTANT=false
LLM_DASHBOARD_INSIGHT=false
LLM_ATTACK_CHAIN_NAMING=false
LLM_PR_DESCRIPTION=false

# Optional OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional AI providers
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional email delivery
RESEND_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=reports@firecrow.dev

# Optional object storage (leave blank when REPORT_LOCAL_FALLBACK=true)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=firecrow-reports

# Docker Compose helpers
IMAGE_TAG=
POSTGRES_PASSWORD=
REDIS_PASSWORD=
