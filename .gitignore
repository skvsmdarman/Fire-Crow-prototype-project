# ===========================
# Fire Crow .gitignore
# ===========================

# ===========================
# Production & Logs
# ===========================
*.log
logs/
*.pid
*.out
*.err

# ===========================
# Artifacts & Debug Output
# ===========================
artifacts/

# ===========================
# Databases
# ===========================
*.db
*.db-journal
*.db-wal
*.db-shm

# ===========================
# Environment & Secrets
# ===========================
.env
*.env.local
*.env.production
!.env.example

# ===========================
# Python
# ===========================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# ===========================
# Virtual Environments
# ===========================
.venv/
venv/
env/
ENV/
.python-version

# ===========================
# Frontend / Node.js
# ===========================
.next/
out/
.turbo/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel/
.npm/
tsconfig.tsbuildinfo

# ===========================
# Testing & Coverage
# ===========================
__mocks__/
mock_data/
test_data/
*.mock.ts
*.mock.js
*.mock.py
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage/
coverage.xml
*.cover

# ===========================
# Type Checking & Linting
# ===========================
.mypy_cache/
.pyright/
.ruff_cache/
eslintcache/

# ===========================
# IDE / Editor
# ===========================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*~
.project
.settings/
.classpath
*.code-workspace

# ===========================
# OS Files
# ===========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ===========================
# Temporary & Backup Files
# ===========================
*.bak
*.swp
*.tmp
*.temp
*.orig

# ===========================
# Workspace Directories
# ===========================
workspace/
backend/workspace/

# ===========================
# Planning & Config (Local Only)
# ===========================
PLAN.md
.opencode/
.claude/

# ===========================
# Build Artifacts
# ===========================
*.manifest
*.spec

# ===========================
# Docker
# ===========================
docker-compose.override.yml

# ===========================
# Celery
# ===========================
celerybeat-schedule
celerybeat.pid

# ===========================
# Redis
# ===========================
dump.rdb

# ===========================
# WeasyPrint / PDF
# ===========================
*.pdf.tmp

# ===========================
# Patch Scripts (one-off)
# ===========================
patch_*.py

# ===========================
# Root Legacy Files
# ===========================
/index.html
/package.json
/package-lock.json
